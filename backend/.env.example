# Supabase Connection Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # keep this secret; backend-only (never expose on frontend)


# SMTP Email Configuration (For sending certificates to interns via Gmail/SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password  # Note: Use App Passwords for Gmail
SMTP_FROM_EMAIL=your-sender-email@gmail.com
SMTP_FROM_NAME=Your Company Name

# Base URLs
BACKEND_BASE_URL=https://your-backend-domain.com  # Used to register document urls in Supabase database
CERT_VERIFY_BASE_URL=https://coptercode-website.vercel.app/verify  # Points to the main CopterCode website /verify route

# Email HTML Template URLs (used in the intern congratulations email)
INTERN_PORTAL_BASE_URL=https://your-main-site.com/intern-portal  # Base URL for the "Download Certificates" CTA button
EMAIL_LOGO_URL=https://your-main-site.com/coptercode-logo.svg    # Public URL of the CopterCode logo shown in the email header
EMAIL_HERO_IMAGE_URL=https://your-main-site.com/hero-3.jpg       # Public URL of the hero/banner image shown in the email